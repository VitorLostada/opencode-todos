{
  "name": "opencode-todos",
  "version": "0.1.0",
  "description": "/todos plugin for OpenCode TUI.",
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "exports": {
    "./tui": {
      "config": {
        "storageScope": "global"
      },
      "types": "./dist/tui.d.ts",
      "import": "./dist/tui.js"
    }
  },
  "scripts": {
    "build": "bun run scripts/build.ts",
    "typecheck": "bun x tsc -p tsconfig.json"
  },
  "dependencies": {
    "@opencode-ai/plugin": "1.4.7",
    "@opentui/solid": "0.1.97",
    "solid-js": "^1.9.9"
  },
  "devDependencies": {
    "@opentui/core": "0.1.97",
    "@types/bun": "latest",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "@opentui/core": ">=0.1.97",
    "@opentui/solid": ">=0.1.97"
  },
  "peerDependenciesMeta": {
    "@opentui/core": {
      "optional": true
    },
    "@opentui/solid": {
      "optional": true
    }
  },
  "engines": {
    "opencode": "^1.4.0"
  },
  "packageManager": "bun@1.3.2"
}
